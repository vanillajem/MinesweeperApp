@model MinesweeperApp.Models.GameBoardViewModel

@{
    // Added by Angela: this partial only renders one cell for AJAX updates.
    int row = (int)ViewData["Row"];
    int col = (int)ViewData["Col"];
    int index = (row * Model.BoardSize) + col;
}

<button class="cell-button"
        data-flagged="@(Model.Board.Grid[row][col].IsFlagged.ToString().ToLower())"
        id="cell-@row-@col"
        data-row="@row"
        data-col="@col"
        data-board-size="@Model.BoardSize"
        data-difficulty="@Model.Difficulty"
        onmouseover="this.style.opacity=0.8"
        onmouseout="this.style.opacity=1"
        style="
    width:60px;
    height:60px;
    font-size:20px;
    font-weight:bold;
    background-color:@(Model.Cells[index] == "" ? "#6c757d" : "#e9ecef");
    color:black;
    border:2px solid #495057;
    border-radius:6px;
    ">
    @Model.Cells[index]
</button>
