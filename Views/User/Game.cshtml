@model MinesweeperApp.Models.GameBoardViewModel

@{
    ViewData["Title"] = "Game Board";
}

<h1>Minesweeper Board</h1>
<h4>Game Setup</h4>
<hr />

<!-- Show the selected game settings -->
<div class="alert alert-info">
    <strong>Board Size:</strong> @Model.BoardSize x @Model.BoardSize <br />
    <strong>Difficulty:</strong> @Model.Difficulty
</div>

@if (TempData["Milestone4Message"] != null)
{
    <div class="alert alert-warning">
        @TempData["Milestone4Message"]
    </div>
}

@* Added by Angela: Milestone 4 frontend controls for saving and viewing saved games. *@
<div class="mb-3">
    <form asp-controller="User" asp-action="SaveGame" method="post" class="d-inline">
        @Html.AntiForgeryToken()
        <input type="hidden" name="boardSize" value="@Model.BoardSize" />
        <input type="hidden" name="difficulty" value="@Model.Difficulty" />
        <button type="submit" class="btn btn-primary me-2">Save Game</button>
    </form>

    <a asp-controller="User" asp-action="ShowSavedGames" class="btn btn-outline-secondary">
        Show Saved Games
    </a>
</div>

@if (Model.ClickedRow != null && Model.ClickedCol != null)
{
    <div class="alert alert-secondary">
        <strong>Last Cell Clicked:</strong>
        Row @Model.ClickedRow, Column @Model.ClickedCol
    </div>
}

@* Added by Angela: timestamp shows AJAX updates without full page reload *@
<div id="timestamp" class="mb-3">
    Last Updated: Not clicked yet
</div>

<!--
    
    Each button is rendered in a grid, and each click posts back to the controller.
    The current board state is stored in the ViewModel.
-->
<div style="display:grid; grid-template-columns: repeat(@Model.BoardSize, 60px); gap: 5px; margin-top: 20px;">
    @* Updated by Jacob to allow Ajax to reveal all adjacent empty cells *@
    <partial name="_BoardPartial" model="Model" />
</div>
<!-- Board grid ends here -->
<!-- Test buttons go OUTSIDE the board grid -->

@* REMOVE THE TEST BUTTONS FOR FINAL PRODUCT
<div class="mt-4">
    <a asp-controller="User" asp-action="Win" asp-route-score="150" class="btn btn-success me-2">
        Test Win Page
    </a>

    <a asp-controller="User" asp-action="Loss" class="btn btn-danger">
        Test Loss Page
    </a>
</div>
*@

@section Scripts {
    <script src="~/js/minesweeper.js"></script>
}
